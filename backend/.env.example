# ─────────────────────────────────────────────
# MongoDB Connection
# ─────────────────────────────────────────────
MONGO_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/jobhunt

# ─────────────────────────────────────────────
# JWT Secret (make this long and random)
# ─────────────────────────────────────────────
SECRET_KEY=your_super_secret_jwt_key_here

# ─────────────────────────────────────────────
# Cloudinary (for profile photos & resumes)
# ─────────────────────────────────────────────
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret

# ─────────────────────────────────────────────
# Google OAuth 2.0
# Steps to get these:
#   1. Go to https://console.cloud.google.com
#   2. Create a new project (e.g. "JobHunt")
#   3. Go to APIs & Services → Credentials
#   4. Create OAuth 2.0 Client ID (Web Application)
#   5. Add Authorized redirect URI:
#      http://localhost:8000/api/v1/user/auth/google/callback
#   6. Copy Client ID and Client Secret below
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/user/auth/google/callback

# ─────────────────────────────────────────────
# Frontend URL (used for redirect after Google login)
# ─────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=8000
NODE_ENV=development
