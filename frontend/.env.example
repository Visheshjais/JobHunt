# ─────────────────────────────────────────────────────────────────────────────
# Frontend Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: All Vite env variables MUST start with VITE_
#   Otherwise they won't be available in the browser code.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API base URL ──────────────────────────────────────────────────────
# Development: point to your local backend
VITE_API_URL=http://localhost:8000/api

# Production (Vercel): replace with your deployed backend URL
# VITE_API_URL=https://your-jobhunt-backend.vercel.app/api
